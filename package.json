{
  "name": "baileys-caller",
  "version": "0.1.0",
  "description": "WhatsApp voice calling SDK for Node.js. Built on Baileys, audio via WhatsApp Web's WASM stack.",
  "author": "ShellTear",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "assets/wasm/whatsapp.wasm",
    "assets/wasm/loader.js",
    "assets/wasm/worker-modules.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.worker.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "check": "npm test && npm audit --audit-level=high",
    "benchmark": "npm run build && node scripts/benchmark-runtime.mjs",
    "benchmark:audio": "npm run build && node scripts/benchmark-audio.mjs",
    "example": "tsx examples/call.mts",
    "fetch-wasm": "node scripts/fetch-wasm-resources.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.10.0",
    "qrcode-terminal": "^0.12.0"
  },
  "peerDependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "whatsapp",
    "voip",
    "voice-call",
    "baileys",
    "wasm",
    "rtp",
    "opus"
  ],
  "license": "MIT"
}
